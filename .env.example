# =========================================================
# Safe autonomous Binance Spot AI trading platform
# Defaults are safe: no real order can be sent.
# Copy to .env locally; never commit secrets.
# =========================================================

# Paths
SQLITE_DB_PATH=data/db/market_data.sqlite

# General safety
DRY_RUN=true
ENABLE_TESTNET_PAPER_TRADING=true
ENABLE_LOCAL_SIMULATED_PAPER=true
ENABLE_LIVE_TRADING=false
ENABLE_REAL_ORDER_EXECUTION=false
ENABLE_REAL_BINANCE_ACCOUNT=false
ALLOW_AUTO_PROMOTE_TO_REAL=false

# Binance public data
BINANCE_PUBLIC_BASE_URL=https://api.binance.com
BINANCE_RECV_WINDOW_MS=5000

# Binance Spot Testnet / Demo Mode / paper
BINANCE_ENV=demo
BINANCE_REST_BASE_URL=https://demo-api.binance.com/api
BINANCE_WS_API_URL=wss://demo-ws-api.binance.com/ws-api/v3
BINANCE_WS_STREAM_URL=wss://demo-stream.binance.com/ws
BINANCE_WS_COMBINED_STREAM_URL=wss://demo-stream.binance.com/stream
BINANCE_DEMO_API_KEY=
BINANCE_DEMO_API_SECRET=
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision

# Binance real account (disabled by default)
BINANCE_REAL_API_KEY=
BINANCE_REAL_API_SECRET=
BINANCE_REAL_BASE_URL=https://api.binance.com

# Universe
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
TIMEFRAME=1h

# Model pool
# multi_symbol = one model across all symbols; per_symbol = one model per crypto; both = train/compare both.
TRAINING_SCOPE=both
TARGET_ACCEPTED_MODELS=5
MAX_TRAINING_ATTEMPTS_PER_CYCLE=50
AUTO_REPLACE_REJECTED_MODELS=true
ENABLE_MODEL_POOL_MAINTENANCE=true
MODEL_POOL_TRAINING_ENABLED_IN_BOT=true
MODEL_POOL_VALIDATION_MAX_FOLDS=5

# Temporal training
TRAINING_CUTOFF_HOURS_BEFORE_NOW=168
VALIDATION_WINDOW_HOURS=168
WALK_FORWARD_ENABLED=true

# Paper validation
MIN_PAPER_VALIDATION_DAYS=7
MIN_PAPER_VALIDATION_TRADES=20
PAPER_MIN_PROFIT_FACTOR=1.05
PAPER_MAX_DRAWDOWN=0.08
PAPER_MIN_TOTAL_RETURN=0.00
PAPER_MIN_WIN_RATE=0.45

# Risk
MAX_EXPOSURE_PER_MODEL_USDT=100
MAX_EXPOSURE_TOTAL_USDT=500
MAX_POSITION_PCT_PER_SYMBOL=0.20
MAX_DAILY_LOSS_USDT=50
MAX_TRADES_PER_DAY_PER_MODEL=10
MAX_ORDER_NOTIONAL_USDT=50
MIN_ORDER_NOTIONAL_USDT=10
KILL_SWITCH_ENABLED=true

# Bot runtime
BOT_POLL_SECONDS=60
MODEL_EVALUATION_INTERVAL_SECONDS=3600
MODEL_MAINTENANCE_INTERVAL_SECONDS=3600
DASHBOARD_REFRESH_SECONDS=30
