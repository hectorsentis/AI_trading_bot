# Binance API.
# Prefer read-only mainnet credentials for account inspection.
# Use separate Spot Testnet credentials for any future execution testing.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_RECV_WINDOW_MS=5000
BINANCE_USE_TESTNET=False
TARGET_ACCEPTED_MODELS=3
ENABLE_MODEL_POOL_MAINTENANCE=True
MODEL_POOL_MAX_TRAINING_ATTEMPTS_PER_CYCLE=4
MODEL_POOL_VALIDATION_MAX_FOLDS=5
MODEL_POOL_TRAINING_ENABLED_IN_BOT=True

# Safety defaults
ENABLE_TRADING=False
DRY_RUN=True
MODEL_POOL_MAINTENANCE_INTERVAL_SECONDS=3600
